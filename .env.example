APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./summary_bot.db
ENABLE_SCHEDULER=false
TIMEZONE=Asia/Shanghai
MESSAGE_SOURCE=none
MESSAGE_SOURCE_PATH=./data/mock_messages.jsonl
POLL_INTERVAL_SECONDS=60
HOURLY_SUMMARY_INTERVAL_SECONDS=3600
QQ_ALLOWED_GROUPS=
QQ_GROUP_FILTER_MODE=exact
QQ_NOTIFICATION_APP_NAMES=QQ,linuxqq,com.tencent.qq,com.tencent.mobileqq
QQ_CAPTURE_PRIVATE_CHATS=false
COLLECTOR_SHARED_TOKEN=change-me
MOBILE_TITLE=Summary Bot
ALERT_CHANNELS=console
KEYWORD_RULES_PATH=./data/keyword_rules.json
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=3
OPENAI_TEMPERATURE=0.1
CLASSIFIER_LLM_RULE_THRESHOLD=2.5
CLASSIFIER_CRITICAL_RULE_THRESHOLD=8.5
CLASSIFIER_HIGH_RULE_THRESHOLD=6.0
